{
  "format_name": "haemonc_uranus_v1",
  "format_version": "1.0",

  "fingerprint": [
    { "sheet": "summary", "cell": "A5", "equals": "Subpanel analysed" },
    { "sheet": "summary", "cell": "A6", "equals": "M-code" },
    { "sheet": "m_codes", "exists": true }
  ],

  "sheets": {
    "summary": {
      "extraction_type": "label_scan",
      "scan_column": "A",
      "value_column": "B",
      "fields": [
        { "db_column": "sample_id",              "label": "Sample ID",         "required": true },
        { "db_column": "date_last_evaluated",    "label": "Date",              "type": "date",
          "default": "today" },
        { "db_column": "preferred_condition_name","label": "Subpanel analysed" },
        { "db_column": "panel",                  "label": "M-code" },
        { "db_column": "ref_genome",             "label": "Reference:",        "default": "not_defined" }
      ]
    },

    "included": {
      "extraction_type": "tabular",
      "columns": [
        { "source": "CHROM",                    "db_column": "chromosome" },
        { "source": "POS",                      "db_column": "start" },
        { "source": "SYMBOL",                   "db_column": "gene_symbol" },
        { "source": "HGVSc",                    "db_column": "hgvsc" },
        { "source": "Consequence",              "db_column": "consequence" },
        { "source": "AF",                       "db_column": "allele_frequency" },
        { "source": "Classification",           "db_column": "germline_classification" },
        { "source": "Latest Classification Date","db_column": "date_last_evaluated",
          "type": "date" },
        { "source": "Comment",                  "db_column": "classification_comment" },
        { "source": "Interpreted",              "db_column": "interpreted",
          "transform": "boolean_to_yes_no" }
      ],
      "generated_columns": [
        { "db_column": "local_id",   "generation": "uuid_time" },
        { "db_column": "linking_id", "source": "local_id" }
      ]
    }
  },

  "merge_strategy": {
    "summary_x_included": { "how": "cross" }
  },

  "constant_fields": {
    "collection_method": "clinical testing",
    "allele_origin":     "somatic",
    "affected_status":   "yes"
  },

  "normalisations": [
    { "field": "germline_classification", "replace": {
        "Likely_pathogenic":       "Likely pathogenic",
        "Uncertain_significance":  "Uncertain significance",
        "Likely_oncogenic":        "Likely oncogenic",
        "Uncertain_significance_oncogenic": "Uncertain significance (oncogenic)"
    }}
  ],

  "validations": {
    "field": [
      { "field": "germline_classification", "type": "in_list",
        "values": [
          "Pathogenic", "Likely pathogenic", "Likely_pathogenic",
          "Uncertain significance", "Uncertain_significance",
          "Likely benign", "Benign",
          "Oncogenic", "Likely oncogenic", "Likely_oncogenic",
          "Uncertain significance (oncogenic)", "Uncertain_significance_oncogenic",
          "Likely benign/Likely not oncogenic", "Benign/Not oncogenic"
        ],
        "required": false }
    ]
  }
}
